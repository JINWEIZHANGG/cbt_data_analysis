library(readxl)
df <- read_excel("data/cbtdata.xlsx")
names(df)
#head(df)
#str(df)
# Chunk 2: remove the unrelated columns
library(tidyverse)
df_k <- df %>%
select(Semaine, K1A, K2A, K3A, K4A, K5A, K6A)
head(df_k)
# Chunk 3: reshape to long format
