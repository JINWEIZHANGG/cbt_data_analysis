# Chunk 1: load xlsx data
library(readxl)
df <- read_excel("data/cbtdata.xlsx")
names(df)
#head(df)
#str(df)
library(tidyverse)
df_k <- df %>%
select(Semaine, K1A, K2A, K3A, K4A, K5A, K6A)
View(df_k)
head(df_k)
df_long <- df_k %>%
pivot_longer(
cols = -Semaine,
names_to = "participant",
values_to = "K"
)
head(df_long)
str(df_long)
View(df_long)
sum(is.na(df_long$K))
View(df_long)
colSums(is.na(df_k))
df_long <- df_long %>%
drop_na(K)
sum(is.na(df_long$K))
head(df_long)
df_long %>%
count(participant)
p1 <- ggplot(df_long, aes(x = Semaine, y = K)) +
geom_line() +
geom_point(size = 1) +
facet_wrap(~ participant, ncol = 2) +
labs(
title = "Weekly K time series by participant",
x = "Week",
y = "K"
) +
theme_minimal()
p1
df_lag <- df_long %>%
group_by(participant) %>%
arrange(Semaine, .by_group = TRUE) %>%
mutate(
prev_week = lag(Semaine),
K_lag1 = lag(K),
consecutive = (Semaine - prev_week == 1)
) %>%
ungroup()
head(df_lag, 15)
df_lag_valid <- df_lag %>%
filter(consecutive == TRUE)
df_lag_valid %>%
count(participant)
