library(nonlinearTseries)
# 选一个统计量函数，这里用lag-1 ACF
stat_func <- function(x) cor(x[-length(x)], x[-1], use = "complete.obs")
set.seed(42)
n_surrogates <- 199  # 通常99或199个
surrogate_results <- df_lag_valid %>%
group_by(participant) %>%
group_map(~ {
ts_data <- .x$K
# 计算原始统计量
obs_stat <- stat_func(ts_data)
# 生成surrogate数据并计算统计量
surr_stats <- replicate(n_surrogates, {
surr <- iaafft(ts_data, n.samples = 1, verbose = FALSE)
stat_func(as.numeric(surr))
})
# 双尾p值
p_val <- (sum(abs(surr_stats) >= abs(obs_stat)) + 1) / (n_surrogates + 1)
tibble(
participant = .y$participant,
obs_acf    = obs_stat,
surr_mean  = mean(surr_stats),
surr_sd    = sd(surr_stats),
p_value    = p_val
)
}) %>%
bind_rows()
shuffle_acf <- function(x, n_shuffle = 1000) {
observed <- cor(x[-1], x[-length(x)], use = "complete.obs")
shuffled <- replicate(n_shuffle, {
x_shuf <- sample(x, length(x), replace = FALSE)
cor(x_shuf[-1], x_shuf[-length(x_shuf)], use = "complete.obs")
})
tibble(
observed_acf = observed,
shuffled_mean = mean(shuffled, na.rm = TRUE),
shuffled_sd = sd(shuffled, na.rm = TRUE),
lower_2.5 = quantile(shuffled, 0.025, na.rm = TRUE),
upper_97.5 = quantile(shuffled, 0.975, na.rm = TRUE),
p_two_sided = mean(abs(shuffled) >= abs(observed), na.rm = TRUE)
)
}
shuffle_acf
shuffle_acf <- function(x, n_shuffle = 1000) {
observed <- cor(x[-1], x[-length(x)], use = "complete.obs")
shuffled <- replicate(n_shuffle, {
x_shuf <- sample(x, length(x), replace = FALSE)
cor(x_shuf[-1], x_shuf[-length(x_shuf)], use = "complete.obs")
})
tibble(
observed_acf = observed,
shuffled_mean = mean(shuffled, na.rm = TRUE),
shuffled_sd = sd(shuffled, na.rm = TRUE),
lower_2.5 = quantile(shuffled, 0.025, na.rm = TRUE),
upper_97.5 = quantile(shuffled, 0.975, na.rm = TRUE),
p_two_sided = mean(abs(shuffled) >= abs(observed), na.rm = TRUE)
)
}
shuffle_acf
set.seed(42)
surrogate_results <- df_long %>%
group_by(participant) %>%
arrange(Semaine, .by_group = TRUE) %>%
summarise(
res = list(shuffle_acf(K, n_shuffle = 1000))
) %>%
unnest(res)
surrogate_results
